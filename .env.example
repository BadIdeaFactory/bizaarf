# Neon Auth + Data API endpoints for the bizaarf SPA.
#
# Both values are PUBLIC — the browser sends them with every request and
# security is enforced by Neon Auth (JWT sessions) and Postgres Row Level
# Security, not by keeping these secret. They live in repo Variables in CI, not
# Secrets. Copy this file to `.env` and fill in the URLs from the Neon console.

# Neon Auth base URL (Auth tab → "Auth URL").
VITE_NEON_AUTH_URL=https://your-project.auth.neon.tech

# Neon Data API (PostgREST) base URL (Data API tab), including the REST path.
VITE_NEON_DATA_API_URL=https://your-project.apirest.neon.tech/rest/v1

# Direct Postgres connection string. SECRET — server/CLI only, never bundled
# into the client (no VITE_ prefix). Used locally to apply migrations
# (`npm run migrate`).
DATABASE_URL=postgresql://user:password@your-project.neon.tech/dbname?sslmode=require
