{
	"name": "bizaarf",
	"version": "0.0.0",
	"description": "A showcase of ideas and projects in various stages from the BIF community.",
	"license": "AGPL-3.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": "24"
	},
	"scripts": {
		"dev": "vite",
		"build": "npm run build:check && vite build",
		"build:check": "svelte-check --tsconfig ./tsconfig.json",
		"preview": "vite preview",
		"format": "npm run format:eslint && npm run format:prettier",
		"format:eslint": "eslint . --fix || true",
		"format:prettier": "prettier . --write",
		"lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:svelte",
		"lint:eslint": "eslint . --max-warnings=0",
		"lint:prettier": "prettier . --check",
		"lint:svelte": "svelte-check --tsconfig ./tsconfig.json",
		"test": "npm run test:unit",
		"test:unit": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^25.9.3",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
